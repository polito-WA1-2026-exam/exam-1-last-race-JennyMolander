# Try valid login
POST http://localhost:3001/api/sessions HTTP/1.1
content-type: application/json

{
    "username": "JennyMol",
    "password": "Password"
}
###

# Try invalid login
POST http://localhost:3001/api/sessions HTTP/1.1
content-type: application/json

{
    "username": "JennyMol",
    "password": "Pasword"
}
###

# Get current user
GET http://localhost:3001/api/sessions/current HTTP/1.1

###

# Log out
DELETE http://localhost:3001/api/sessions/current HTTP/1.1

###

# Get full network
GET http://localhost:3001/api/network HTTP/1.1

###

# Get ranking
GET http://localhost:3001/api/ranking HTTP/1.1

###

# Create game
POST http://localhost:3001/api/games HTTP/1.1

###
# Get current game
GET http://localhost:3001/api/games/current HTTP/1.1

###

# Get game by id
GET http://localhost:3001/api/games/3 HTTP/1.1

###

# Get segments
GET http://localhost:3001/api/segments HTTP/1.1

###

# Send route
POST http://localhost:3001/api/games/2/route HTTP/1.1
content-type: application/json

{
    "route": [
        {"fromStationId": 2, "toStationId": 5},
        {"fromStationId": 5, "toStationId": 8},
        {"fromStationId": 8, "toStationId": 9}
    ]
}
###

# execute segment
POST http://localhost:3001/api/games/7/step HTTP/1.1
content-type: application/json

{
    "route": [
        {"fromStationId": 9, "toStationId": 8},
        {"fromStationId": 8, "toStationId": 5},
        {"fromStationId": 5, "toStationId": 1}
    ],
    "stepIndex": 2
}
###

# End game
POST http://localhost:3001/api/games/3/abandon HTTP/1.1

###